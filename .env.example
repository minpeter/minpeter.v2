# Copy this file to .env.local and fill in the values

# Node environment (development, production, test)
NODE_ENV=development

# Custom port for local development (default: 3000)
# PORT=3000

# Production base URL (takes priority over VERCEL_URL)
# PUBLIC_BASE_URL=https://minpeter.com

# Vercel deployment URL (auto-injected)
# VERCEL_URL=

# Vercel environment (production, preview, development) (auto-injected)
# VERCEL_ENV=

# Public Vercel environment for client-side usage
# NEXT_PUBLIC_VERCEL_ENV=

# Enable bundle analyzer (set to "true" to enable)
# ANALYZE=false

# Skip environment validation (not recommended for production)
# SKIP_ENV_VALIDATION=false
